# Savia — Configuration Template
# Copy this file to .env and fill in your values

# ─── Core Application ────────────────────────────────────────────────
DEBUG=false
ENGINE_VERSION=savia-mvp-v1

# ─── Confidence Thresholds (0.0 to 1.0) ──────────────────────────────
# CONFIDENCE_THRESHOLD_ESCALATE: Below this score → require human review
CONFIDENCE_THRESHOLD_ESCALATE=0.40

# CONFIDENCE_THRESHOLD_AI: Above this score → fully trust AI decision
CONFIDENCE_THRESHOLD_AI=0.90

# ─── AI Features ─────────────────────────────────────────────────────
AI_ENABLED=true
AI_PROVIDER=openai  # Options: openai, mock

# ─── SonarCloud Analysis ─────────────────────────────────────────────
# Get your token from: https://sonarcloud.io/account/security/
# Then: make sonar  (Makefile will use this token)
SONAR_TOKEN=your_sonarcloud_token_here

